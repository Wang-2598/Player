{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Player (软解)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Player.exe",
            "args": [
                "c:/Users/zhao-lenovo/Videos/bbb_sunflower_1080p_30fps_normal.mp4"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build"
        },
        {
            "name": "Player (硬解 NVDEC)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Player.exe",
            "args": [
                "--hw",
                "c:/Users/zhao-lenovo/Videos/bbb_sunflower_1080p_30fps_normal.mp4"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build"
        }
    ]
}
